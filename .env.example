# Jira Configuration

# Jira base URL (required)
JIRA_URL=https://issues.redhat.com

# Authentication - choose ONE method:

# Option 1: Data Center (Personal Access Token)
JIRA_PERSONAL_TOKEN=your-personal-access-token-here

# Option 2: Jira Cloud (Basic Auth)
# JIRA_USERNAME=your@email.com
# JIRA_API_TOKEN=your-api-token-here

# LLM Model (optional, default: anthropic:claude-sonnet-4-6)
# MODEL=anthropic:claude-sonnet-4-6
# MODEL=openai:gpt-4
# MODEL=google-gla:gemini-1.5-pro
